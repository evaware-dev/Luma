{
	"schemaVersion": 1,
	"id": "luma-renderer",
	"version": "${version}",
	"name": "Luma Renderer",
	"description": "OpenGL wrapper",
	"accessWidener": "luma-renderer.accesswidener",
	"authors": [
		"Remila"
	],
	"license": "MIT",
	"icon": "assets/luma-renderer/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "sweetie.evaware.LumaRenderer",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"luma-renderer.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
